pipeline {
    agent any
    
    stages {
        stage('Build') {
            steps {
                script {
                    // Define o nome da imagem Docker
                    def dockerImage = 'flask_crud_app:0.0.1'
                    
                    // Constrói a imagem Docker usando o Dockerfile no diretório atual
                    docker.build dockerImage, '-f Dockerfile .'
                    
                    // Opcional: Faça o push da imagem para um registry (como Docker Hub)
                    // docker.withRegistry('https://registry_url', 'registry_credentials') {
                    //     dockerImage.push()
                    // }
                }
            }
        }
    }
}