pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = 'flask_crud_app:0.0.1'
    }
    
    stages {
        stage('Build') {
            steps {
                script {
                    def dockerImage = docker.build(env.DOCKER_IMAGE)
                    dockerImage.inside {
                        // Aqui você colocaria os comandos para construir sua aplicação Flask
                        // Por exemplo: instalar dependências, compilar, etc.
                        sh 'echo "Construindo a aplicação Flask..."'
                    }
                }
            }
        }
        
        stage('Deploy') {
            steps {
                script {
                    // Aqui você poderia adicionar comandos para fazer o push da imagem para um registro Docker, por exemplo.
                    sh 'echo "Deploy da imagem Docker $DOCKER_IMAGE"'
                }
            }
        }
    }
}